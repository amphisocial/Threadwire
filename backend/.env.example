# ThreadWire backend configuration. Copy to `.env` and fill in.
# NEVER commit the real .env. Keep secrets on the server only.

DATABASE_URL=postgresql://threadwire:CHANGE_ME@localhost:5432/threadwire

# Master key for encrypting connector secrets at rest (base64 of 32 random bytes).
# Generate with:
#   python -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode())"
TW_SECRET_KEY=

# ----- AI PROVIDER -----------------------------------------------------------
# Pick which model powers the assistant: openai | gemini | anthropic
AI_MODEL=anthropic

# Your Anthropic API key. The browser NEVER sees any key — the backend proxies AI calls.
ANTHROPIC_API_KEY=
# Check https://docs.claude.com for the current model string before going live.
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024

# OpenAI (used when AI_MODEL=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (used when AI_MODEL=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Cookies: keep true in production (HTTPS). Set false only for local http testing.
COOKIE_SECURE=true
SESSION_DAYS=14

# Public base URL used in invite links
APP_BASE_URL=https://threadwire.ai

# Invite emails (OPTIONAL). If unset, the admin just copies the invite link.
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=you@gmail.com,
# SMTP_PASS=<16-char app password>, SMTP_FROM="ThreadWire <you@gmail.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ----- BILLING (Stripe) -----------------------------------------------------
# Card entry happens on Stripe's hosted Checkout; secret keys stay on the server.
# PAYMENT_MODE selects which key/price set is used:
#   test  -> sandbox keys, NO real charges (safe default)
#   prod  -> live keys, REAL card charges
PAYMENT_MODE=test

# Test (sandbox) set — used when PAYMENT_MODE=test
STRIPE_SECRET_KEY_TEST=
STRIPE_PRICE_PRO_TEST=
STRIPE_PRICE_ENTERPRISE_TEST=

# Live set — used when PAYMENT_MODE=prod  (real money)
STRIPE_SECRET_KEY_LIVE=
STRIPE_PRICE_PRO_LIVE=
STRIPE_PRICE_ENTERPRISE_LIVE=

# Optional single-set fallback (used if the mode-specific vars above are blank)
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# Free tier: assistant messages per user per day (auto-resets daily)
FREE_DAILY_TOKENS=5
