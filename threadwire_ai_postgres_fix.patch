+async def _page_db_context(con, org_id, page: Optional[str]) -> str:
+    """Return bounded, organization-scoped rows for the active application page.
+
+    Table names come only from PAGE_CONTEXT_TABLES; never accept a table name
+    directly from the request.
+    """
+    tables = PAGE_CONTEXT_TABLES.get((page or "").strip().lower(), ())
+    if not tables:
+        return ""
+
+    sections = [
+        "SERVER DATABASE CONTEXT (Postgres, organization-scoped, authoritative). "
+        "This data overrides any sample/demo data embedded in the client prompt."
+    ]
+    for table in tables:
+        try:
+            rows = await con.fetch(
+                f"SELECT to_jsonb(t) - 'org_id' AS payload "
+                f"FROM {table} AS t WHERE org_id=$1 LIMIT 60",
+                org_id,
+            )
+        except Exception:
+            # Some optional modules/tables may not be installed for every tenant.
+            continue
+        if rows:
+            payload = [r["payload"] for r in rows]
+            sections.append(f"{table.upper()} = {json.dumps(payload, default=str)}")
+
+    # Keep the system prompt bounded even when rows contain verbose JSON fields.
+    return "\n".join(sections)[:60000] if len(sections) > 1 else ""
