---
/**
 * Description: Sign-In, Sign-Up, and Create New Customer Modal
 */

import { Icon } from 'astro-icon/components';

// State Management
let isCustomerModalOpen = false;

// State Management
let isSignUp = false;
---
<!-- Main Authentication Modal -->
<div id="authModal" class="modal hidden fixed inset-0 z-50">
  <!-- Backdrop -->
  <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

  <!-- Modal Content -->
  <div class="fixed inset-0 z-10 overflow-y-auto">
    <div class="flex min-h-full items-center justify-center p-4">
      <div class="bg-white dark:bg-neutral-800 rounded-lg shadow-xl w-full max-w-md p-6">
        <!-- Header -->
        <div class="flex justify-between items-center mb-6">
          <h2 id="authTitle" class="text-2xl font-bold dark:text-white">
            Welcome Back
          </h2>
          <button
            id="closeModal"
            class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200"
            aria-label="Close modal"
          >
            <Icon name="mdi:close" class="w-6 h-6" />
          </button>
        </div>

        <!-- Form Section -->
        <form id="authForm" class="space-y-4">
          <!-- User ID (Sign-Up Only) -->
          <div id="userIdField" class="hidden">
            <label class="block text-sm font-medium" for="userId">User ID</label>
            <input
              type="text"
              id="userId"
              name="userId"
              placeholder="Enter your User ID"
              class="w-full px-3 py-2 rounded-md border"
            />
          </div>

          <!-- Name (Sign-Up Only) -->
          <div id="nameField" class="hidden">
            <label class="block text-sm font-medium" for="name">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              placeholder="Enter your Name"
              class="w-full px-3 py-2 rounded-md border"
            />
          </div>

          <!-- Email -->
          <div>
            <label class="block text-sm font-medium" for="email">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="Enter your Email"
              required
              class="w-full px-3 py-2 rounded-md border"
            />
          </div>

          <!-- Password -->
          <div>
            <label class="block text-sm font-medium" for="password">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Enter your Password"
              required
              class="w-full px-3 py-2 rounded-md border"
            />
          </div>

          <!-- Confirm Password (Sign-Up Only) -->
          <div id="confirmPasswordField" class="hidden">
            <label class="block text-sm font-medium" for="confirmPassword">Confirm Password</label>
            <input
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              placeholder="Re-enter your Password"
              class="w-full px-3 py-2 rounded-md border"
            />
          </div>

          <!-- Company Dropdown (Sign-Up Only) -->
          <div id="companyField" class="hidden">
            <label class="block text-sm font-medium" for="company">Your Company Name</label>
            <select id="company" name="company" class="w-full px-3 py-2 rounded-md border">
              <option>Select a Customer</option>
              <option>Customer 1</option>
              <option>Customer 2</option>
            </select>
            <p class="text-sm mt-2">
              Don't see your company name?
              <button
                type="button"
                id="openCustomerModal"
                class="text-primary-500 underline"
              >
                Create New Customer
              </button>
            </p>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            id="authSubmitButton"
            class="w-full bg-primary-500 text-white py-2 rounded-md hover:bg-primary-600"
          >
            Sign In
          </button>
        </form>

        <!-- Toggle Auth Mode -->
        <div class="mt-4 text-center">
          <button 
            id="toggleAuthMode" 
            class="text-primary-500 hover:text-primary-600 text-sm mt-4"
          >
            Don't have an account? Sign Up
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Create New Customer Modal -->
<div id="customerModal" class="modal hidden fixed inset-0 z-50">
  <!-- Backdrop -->
  <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity"></div>

  <!-- Modal Content -->
  <div class="fixed inset-0 z-10 overflow-y-auto">
    <div class="flex min-h-full items-center justify-center p-4">
      <div class="bg-white dark:bg-neutral-800 rounded-lg shadow-xl w-full max-w-md p-6">
        <h2 class="text-2xl font-bold mb-4 dark:text-white">Create New Customer</h2>
        <form id="customerForm" class="space-y-4">
          <div>
            <label class="block text-sm font-medium" for="customerName">Customer Name</label>
            <input
              type="text"
              id="customerName"
              name="customerName"
              placeholder="Enter Customer Name"
              class="w-full px-3 py-2 rounded-md border"
            />
          </div>
          <div>
            <label class="block text-sm font-medium" for="address">Address</label>
            <input
              type="text"
              id="address"
              name="address"
              placeholder="Enter Address"
              class="w-full px-3 py-2 rounded-md border"
            />
          </div>
          <div class="flex gap-4">
            <button type="submit" class="w-1/2 bg-blue-500 text-white py-2 rounded-md">Create</button>
            <button
              type="button"
              id="closeCustomerModal"
              class="w-1/2 bg-red-500 text-white py-2 rounded-md"
            >
              Cancel
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- JavaScript Logic -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    let isSignUp = false;

    const toggleButton = document.getElementById('toggleAuthMode');
    const authTitle = document.getElementById('authTitle');
    const authSubmitButton = document.getElementById('authSubmitButton');

    if (!toggleButton || !authTitle || !authSubmitButton) return;

    toggleButton.addEventListener('click', () => {
      isSignUp = !isSignUp;
      authTitle.innerText = isSignUp ? 'Create Account' : 'Welcome Back';
      authSubmitButton.innerText = isSignUp ? 'Sign Up' : 'Sign In';
      toggleButton.innerText = isSignUp 
        ? 'Already have an account? Log in' 
        : "Don't have an account? Sign Up";

      ['userIdField', 'nameField', 'confirmPasswordField', 'companyField'].forEach(id => {
        const element = document.getElementById(id);
        if (element) {
          element.classList.toggle('hidden', !isSignUp);
        }
      });
    });
  });
</script>